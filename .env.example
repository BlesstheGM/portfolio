# Twilio (WhatsApp sandbox) — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=

# Resend (transactional email) — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=Shop Agent <orders@yourdomain.com>
ADMIN_EMAIL=
